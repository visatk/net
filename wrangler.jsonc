{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "raven",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-29",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
    "d1_databases": [
    {
      "binding": "DB",
      "database_name": "viteapp",
      "database_id": "9909fa7a-c277-4b38-96bf-b97a8008dece"
    }
  ],
   "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "bb8ef261cab04944973a633c28673def"
    }
  ]
}
