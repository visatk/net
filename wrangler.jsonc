{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ravenhq",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-29",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
    "d1_databases": [
    {
      "binding": "DB",
      "database_name": "atlas",
      "database_id": "01c4be24-2c0f-449b-9ccc-24481de586f3"
    }
  ],
   "kv_namespaces": [
    {
      "binding": "KV",
      "id": "d467334de0aa4bd58910c266f8ac0233"
    }
  ]
}
